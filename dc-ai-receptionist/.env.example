# Copy to .env.local and fill in real values. Do not commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Server-only. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Vapi
VAPI_API_KEY=<vapi-private-key>
NEXT_PUBLIC_VAPI_PUBLIC_KEY=<vapi-public-key>
VAPI_WEBHOOK_SECRET=<random-32+-char-string>
VAPI_ASSISTANT_ID_BYD=<assistant-id>
VAPI_PHONE_NUMBER_ID=<phone-number-id>
