# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Server-only. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>

# ─── Vapi ─────────────────────────────────────────────────────────────────────
# Found in: Vapi Dashboard → Account → API Keys

VAPI_API_KEY=<vapi-private-api-key>
NEXT_PUBLIC_VAPI_PUBLIC_KEY=<vapi-public-key>

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match the "Server URL Secret" field in Vapi Dashboard → Assistant → Server URL
VAPI_WEBHOOK_SECRET=<random-64-char-hex-string>

# Found in: Vapi Dashboard → Assistants → your assistant → copy ID
VAPI_ASSISTANT_ID=<vapi-assistant-id>

# Found in: Vapi Dashboard → Phone Numbers → your number → copy ID
VAPI_PHONE_NUMBER_ID=<vapi-phone-number-id>
